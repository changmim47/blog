# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real keys.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=your-anon-key-here

# Optional: Google AdSense (활성화 후 설정)
# VITE_ADSENSE_CLIENT만 설정해도 스크립트 로드되어 심사 신청 가능.
# 심사 통과 후 광고 단위 만들고 slot ID 추가하면 광고 채워짐.
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_SLOT_BANNER=1234567890
# VITE_ADSENSE_SLOT_INFEED=1234567890
# VITE_ADSENSE_SLOT_RECTANGLE=1234567890

# Used by scripts/generate-post.ts (server-side only — not exposed to browser)
SUPABASE_ADMIN_EMAIL=admin-account-email@example.com
SUPABASE_ADMIN_PASSWORD=admin-account-password
ANTHROPIC_API_KEY=your-anthropic-api-key-from-console.anthropic.com

# Optional: Unsplash for cover images (script falls back to picsum if missing)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-from-unsplash.com/developers

# Optional: Telegram notification (script will skip if not set)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-numeric-chat-id
BLOG_BASE_URL=https://your-deployed-blog.vercel.app
